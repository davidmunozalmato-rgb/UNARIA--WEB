# Database
DATABASE_URL="postgresql://unaria:password@localhost:5432/unaria_db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars-here"

# Admin credentials (hashed password stored in DB via seed)
ADMIN_EMAIL="admin@unaria.org"
ADMIN_PASSWORD="change-me-in-production"

# Stripe
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend (email)
RESEND_API_KEY="re_..."
EMAIL_FROM="Unaria <noreply@unaria.org>"
ADMIN_EMAIL_NOTIFICATIONS="admin@unaria.org"

# Encryption (AES-256, 32-byte hex key)
ENCRYPTION_KEY="your-32-byte-hex-key-here-64-chars"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Rate limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60000

# Cron jobs (Vercel sends this as Bearer token)
CRON_SECRET="your-cron-secret-here"
