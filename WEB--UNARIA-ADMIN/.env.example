# Database (SAME as public web — read+write)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# NextAuth — DIFFERENT secret from public web!
NEXTAUTH_URL="https://admin.unaria.org"
NEXTAUTH_SECRET="generate-a-new-random-secret-min-32-chars"

# Admin credentials (used only by seed)
ADMIN_EMAIL="admin@unaria.org"
ADMIN_PASSWORD="change-me-strong-password"

# App
NEXT_PUBLIC_APP_URL="https://admin.unaria.org"
